<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="CrepdogCrew App Test Regression Suite" verbose="4"
	thread-count="2" parallel="tests">
	
	<listeners>
		<listener class-name="com.aventstack.chaintest.plugins.ChainTestListener" />
		<listener class-name="com.qa.CrepdogCrewUIAutomation.listeners.TestAllureListener" />
		<listener class-name="com.qa.crepdogcrew.listeners.AnnotationTransformer" />
	</listeners>
	
	<test name="Home Page Test_firefox">
		<parameter name="browser" value="firefox" />
		<classes>
			<class name="com.qa.crepdogcrew.tests.HomepageTest" />
		</classes>
	</test>
	
	  <test name="Login Page Test_firefox">
		<parameter name="browser" value="firefox" />
		<classes>
			<class name="com.qa.crepdogcrew.tests.LoginpageTest" />
		</classes>
	</test>  


</suite>	